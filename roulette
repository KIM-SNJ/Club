#include <time.h>
#include <windows.h>
#include <conio.h>
#include <stdio.h>

int main() {
    int a = 0;
    int b = 0;
    int c = 0;
    srand(time(NULL));

    printf("    숫자를 뽑아주세요!\n");

    while (1) {
        if (!_kbhit()) {
            a = rand() % 10;
            printf("\r  [ %d |   |   ] ", a);
            Sleep(50);
        }
        else {
            _getch();
            break;
        }
    }
    while (1) {
        if (!_kbhit()) {
            b = rand() % 10;
            printf("\r  [ %d | %d |   ] ", a, b);
            Sleep(50);
        }
        else {
            _getch();
            break;
        }
    }
    while (1) {
        if (!_kbhit()) {
            c = rand() % 10;
            printf("\r  [ %d | %d | %d ] ", a, b, c);
            Sleep(50);
        }
        else {
            _getch();
            break;
        }
    }
    if (a == 7 && b == 7 && c == 7) {
        printf("\n    잭팟!");
    }
    else {
        printf("\n    다시 시도해보세요");
    }
}
